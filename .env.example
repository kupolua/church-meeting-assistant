# =================================================================
# Church Meeting Assistant — Environment Variables
# =================================================================
# Copy this file to .env and fill in real values.
# .env should be in .gitignore (do not commit secrets).
# =================================================================


# ─────────────────────────────────────────────────────────────
# Existing (from Phase 2A/2B)
# ─────────────────────────────────────────────────────────────

# Voyage AI (embeddings + rerank)
VOYAGE_API_KEY=your_voyage_api_key_here

# Hugging Face (pyannote-audio)
HF_TOKEN=your_huggingface_token_here


# ─────────────────────────────────────────────────────────────
# NEW: Database (Phase 3 / MVP-A)
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=cma
DB_USER=cma
DB_PASSWORD=changeme_to_strong_random_password

# Constructed DATABASE_URL (asyncpg format)
# Example: postgresql://cma:changeme@127.0.0.1:5432/cma
# (built by code from above, but exposed here as fallback)
# DATABASE_URL=postgresql://cma:changeme_to_strong_random_password@127.0.0.1:5432/cma


# ─────────────────────────────────────────────────────────────
# NEW: Telegram bot (Phase 3 / MVP-A)
# ─────────────────────────────────────────────────────────────

# From @BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Pavlo's Telegram user ID (numeric)
# To get: send any message to bot, look at logs (bot will log unknown user_id)
PAVLO_TELEGRAM_USER_ID=

# Bot polling timeout (long polling, seconds)
TELEGRAM_POLL_TIMEOUT=30


# ─────────────────────────────────────────────────────────────
# NEW: Service URLs (Phase 3 / MVP-A)
# ─────────────────────────────────────────────────────────────

# Ollama (local M1)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:26b
OLLAMA_TIMEOUT=600  # seconds; Gemma can be slow

# Qdrant (Docker)
QDRANT_URL=http://localhost:6333
QDRANT_TIMEOUT=30


# ─────────────────────────────────────────────────────────────
# NEW: Worker config (Phase 3 / MVP-A)
# ─────────────────────────────────────────────────────────────

# Polling intervals (seconds)
WORKER_POLL_INTERVAL=10           # When idle, check for pending
WORKER_HEALTH_CHECK_INTERVAL=60   # Health check frequency
WORKER_RETRY_SLEEP=60             # When Ollama/Qdrant down, wait this long

# Retry policy
WORKER_MAX_RETRIES=3


# ─────────────────────────────────────────────────────────────
# NEW: Ingestion worker config (MVP-C — audio → protocol)
# ─────────────────────────────────────────────────────────────
# Separate background worker (church_assistant.ingestion.main) that drives the
# long audio → protocol pipeline. Runs alongside the query worker.

INGESTION_POLL_INTERVAL=15         # When idle, check for runnable jobs
INGESTION_HEALTH_CHECK_INTERVAL=60 # Health snapshot frequency (gating only)
INGESTION_RETRY_SLEEP=60           # When Ollama/Qdrant down, wait this long

# Retry policy — pipeline steps are expensive, so keep this low
INGESTION_MAX_RETRIES=2

# Run diarization + transcription sequentially (lower peak RAM; slower)
INGESTION_SEQUENTIAL=false

# Auto-index the finished protocol into Qdrant (full cycle)
INGESTION_AUTO_INDEX=true
